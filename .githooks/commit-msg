#!/bin/sh
# Conventional Commits header check (dependency-free).
# Enable once per clone:  git config core.hooksPath .githooks
# Format:  type(scope)!: subject   e.g.  fix(audio): stop restarting audioserver per toggle

msg_file="$1"
header=$(head -n1 "$msg_file")

# Let git's own machinery (merges, reverts, fixup/squash) through untouched.
case "$header" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+'

if printf '%s' "$header" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
✗ Commit message must follow Conventional Commits:

    type(scope)!: subject

  types: feat fix docs style refactor perf test build ci chore revert
  (append ! before the colon, or add a "BREAKING CHANGE:" footer, for breaking changes)

  Only feat/fix (and breaking changes) bump the released version.
EOF
printf '  got: %s\n' "$header" >&2
exit 1
